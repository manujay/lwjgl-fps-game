# Simplified Space Shuttle OBJ

# Vertices (positions)
v  0.0  0.0  0.0    # nose tip
v  0.5  0.2 -2.0    # right nose base
v -0.5  0.2 -2.0    # left nose base
v  0.5 -0.2 -2.0    # right underside nose
v -0.5 -0.2 -2.0    # left underside nose
v  0.8  0.3 -5.0    # right fuselage mid
v -0.8  0.3 -5.0    # left fuselage mid
v  0.8 -0.3 -5.0    # right fuselage bottom
v -0.8 -0.3 -5.0    # left fuselage bottom
v  0.0  0.0 -8.0    # tail end

# Wings (simplified flat panels)
v  3.0  0.0 -4.0    # right wing tip
v -3.0  0.0 -4.0    # left wing tip

# Tail fin
v  0.0  2.0 -8.0    # vertical stabilizer top

# Texture coordinates (UVs)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normals (basic directions)
vn  0  0  1   # forward
vn  0  0 -1   # backward
vn  1  0  0   # right
vn -1  0  0   # left
vn  0  1  0   # up
vn  0 -1  0   # down

# Faces (triangles with v/vt/vn)
# Nose cone
f 1/1/1 2/2/1 3/3/1
f 1/1/1 4/2/1 5/3/1

# Fuselage
f 2/1/2 6/2/2 7/3/2
f 3/1/2 7/2/2 6/3/2
f 4/1/6 8/2/6 9/3/6
f 5/1/6 9/2/6 8/3/6

# Tail
f 6/1/2 7/2/2 10/3/2
f 8/1/2 9/2/2 10/3/2

# Wings
f 6/1/3 11/2/3 8/3/3
f 7/1/4 12/2/4 9/3/4

# Tail fin
f 10/1/5 13/2/5 7/3/5