# Cube mesh with normals and UVs

# Vertices (positions)
v -1 -1 -1
v  1 -1 -1
v  1  1 -1
v -1  1 -1
v -1 -1  1
v  1 -1  1
v  1  1  1
v -1  1  1

# Texture coordinates (UVs)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normals
vn  0  0 -1   # front
vn  0  0  1   # back
vn -1  0  0   # left
vn  1  0  0   # right
vn  0  1  0   # top
vn  0 -1  0   # bottom

# Faces (vertex/uv/normal)
# Front face
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Back face
f 5/1/2 6/2/2 7/3/2
f 5/1/2 7/3/2 8/4/2

# Left face
f 1/1/3 4/2/3 8/3/3
f 1/1/3 8/3/3 5/4/3

# Right face
f 2/1/4 3/2/4 7/3/4
f 2/1/4 7/3/4 6/4/4

# Top face
f 4/1/5 3/2/5 7/3/5
f 4/1/5 7/3/5 8/4/5

# Bottom face
f 1/1/6 2/2/6 6/3/6
f 1/1/6 6/3/6 5/4/6
